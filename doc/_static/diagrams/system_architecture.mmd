%%{init: {"theme": "base", "themeVariables": {"primaryColor": "#1a73e8", "primaryTextColor": "#fff", "primaryBorderColor": "#1558b0", "lineColor": "#555", "secondaryColor": "#f8f9fa", "tertiaryColor": "#e8f0fe"}}}%%
flowchart TB
    subgraph APP["User Applications"]
        MA["MoveIt2 / RViz2<br/>(motion planning UI)"]
        UA["Custom Application<br/>(C++ / Python)"]
    end

    subgraph ROS["ROS2 Layer  —  CycloneDDS middleware"]
        direction LR
        MS["manipulator_state<br/>/joint_states @ 500 Hz"]
        FJT["follow_joint_trajectory_server<br/>FollowJointTrajectory action"]
        WEN["wmx_engine_node<br/>/wmx/engine/*"]
        WCM["wmx_core_motion_node<br/>/wmx/axis/*"]
        WIO["wmx_io_node<br/>/wmx/io/*"]
        WEC["wmx_ethercat_node<br/>/wmx/ecat/*"]
    end

    subgraph WMX["WMX API Layer  —  /opt/lmx/ shared libraries"]
        direction LR
        CM["libcoremotionapi<br/>Position / velocity control"]
        AM["libadvancedmotionapi<br/>Cubic spline trajectories"]
        IO["libioapi<br/>Digital I/O (gripper)"]
        EC["libecapi<br/>EtherCAT diagnostics"]
        W3["libwmx3api<br/>Device & engine management"]
    end

    subgraph HW["Hardware Layer"]
        direction LR
        ME["WMX3 Motion Engine<br/>(real-time process)"]
        ECAT["EtherCAT Bus<br/>(dedicated NIC)"]
        SD["Servo Drives<br/>J1 – J6"]
        IOM["I/O Module<br/>(gripper)"]
        ROB["Dobot CR3A<br/>(6-DOF manipulator)"]
    end

    APP -->|"ROS2 topics / services / actions"| ROS
    ROS -->|"C++ shared library calls"| WMX
    WMX -->|"Shared memory → EtherCAT"| HW
    ME --> ECAT --> SD & IOM
    SD & IOM --> ROB
    ROB -->|"Encoder feedback"| SD
    SD -->|"500 Hz feedback loop"| MS
